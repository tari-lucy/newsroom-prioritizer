# Пример переменных окружения. Скопировать в .env и заполнить значения:
#   cp .env.example .env
# Файл .env в репозиторий не коммитится (см. .gitignore).

# --- База данных PostgreSQL ---
DB_HOST=database        # имя сервиса из docker-compose, а не localhost
DB_PORT=5432
DB_USER=newsroom
DB_PASS=newsroom
DB_NAME=newsroom

# --- Очередь задач RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=newsroom
RABBITMQ_PASSWORD=newsroom
RABBITMQ_QUEUE=rewrite_tasks

# --- Внешние порты (поменять, если заняты на сервере) ---
PROXY_PORT=80           # http-вход (API/Swagger); если 80 занят — напр. 8080
WEBVIEW_PORT=8501       # витрина редактора

# --- Приложение ---
DEBUG=false             # true включает SQL-эхо и подробные логи
SEED_SOURCES=true       # создавать дефолтные ленты при первом старте
SEED_EDITOR=true        # создавать демо-редактора (editor / editor123) при первом старте
# DATABASE_URL=         # переопределение строки подключения (напр. sqlite для тестов); пусто -> Postgres

# --- Авторизация (JWT) ---
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-change-me
JWT_EXPIRE_SECONDS=86400

# --- Пайплайн: гео-фильтр (регион — в настройках, не в коде) ---
REGION=sevastopol_crimea        # ключ активного региона в config/region.yml
REGION_CONFIG=/config/region.yml

# Дотягивать полный текст статьи по ссылке (RSS даёт только анонс)
FETCH_FULLTEXT=true

# --- Коннектор ВК (паблики) ---
# Сервисный токен приложения с dev.vk.com. Пусто => vk-источники пропускаются.
VK_TOKEN=

# --- Пайплайн: дедуп и сбор ---
DEDUP_THRESHOLD=0.75           # порог косинуса для «дубль» (RSS-анонсы короче статей; калибруется)
DEDUP_WINDOW_HOURS=48          # окно поиска дублей
INGEST_INTERVAL_MINUTES=30     # период автосбора шедулером

# --- Приоритизатор ---
MODEL_PATH=/config/virality_model.joblib   # обученная модель; нет файла => заглушка-эвристика

# --- Метрика (источник меток для переобучения) ---
# Токен: oauth.yandex.ru, scope metrika:read. Счётчик — номер из кабинета Метрики.
# Пусто => метки не подтягиваются, петля переобучения простаивает.
METRIKA_TOKEN=
METRIKA_COUNTER=

# --- Петля переобучения (trainer) ---
RETRAIN_INTERVAL_DAYS=30     # период переобучения
LABEL_MATURATION_DAYS=30     # сколько ждём созревания метки (просмотры)
RETRAIN_MIN_SAMPLES=200      # минимум размеченных примеров
RETRAIN_GATE_MARGIN=0.0      # кандидат промоутится, если не хуже текущей на эту дельту

# --- LLM рерайта (через vsellm, OpenAI-совместимый API) ---
# Токен — в личном кабинете vsellm. Пустой ключ => рерайт работает на заглушке.
LLM_BASE_URL=https://api.vsellm.ru/v1
LLM_API_KEY=
LLM_MODEL=deepseek/deepseek-v3.2     # id модели из каталога vsellm (напр. gpt-4o, claude-sonnet-4.6)
LLM_TEMPERATURE=0.3

# --- Проверка уникальности рерайта (Text.ru) ---
# Ключ — в личном кабинете text.ru. Пустой ключ => проверка пропускается.
TEXTRU_API_KEY=

# --- Витрина (Streamlit) ---
# Адрес API внутри docker-сети для обращений из webview.
API_URL=http://api:8000
