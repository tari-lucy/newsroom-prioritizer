# Пример переменных окружения. Скопировать в .env и заполнить значения:
#   cp .env.example .env
# Файл .env в репозиторий не коммитится (см. .gitignore).

# --- База данных PostgreSQL ---
DB_HOST=database        # имя сервиса из docker-compose, а не localhost
DB_PORT=5432
DB_USER=newsroom
DB_PASS=newsroom
DB_NAME=newsroom

# --- Очередь задач RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=newsroom
RABBITMQ_PASSWORD=newsroom
RABBITMQ_QUEUE=rewrite_tasks

# --- Приложение ---
DEBUG=false             # true включает SQL-эхо и подробные логи

# --- Витрина (Streamlit) ---
# Адрес API внутри docker-сети для обращений из webview.
API_URL=http://api:8000
